# Copy to .env and fill values. On Railway, set these in the service Variables UI.

DATABASE_URL=postgresql://user:pass@host:5432/dbname
SECRET_KEY=use-a-long-random-string-in-production

# Required for AI prescription shorthand parsing, interaction hints, and lab analysis helpers.
# Without ANTHROPIC_API_KEY, the API falls back to offline parsing only (limited).
ANTHROPIC_API_KEY=
# Optional; default in app is claude-3-5-haiku-latest (see app/config.py)
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# WhatsApp / Meta Graph API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WEBHOOK_VERIFY_TOKEN=

# WhatsApp template names
INTERAKT_LANGUAGE_CODE=en
INTERAKT_TEMPLATE_THANK_YOU=docnudge_thank_you_after_visit
INTERAKT_TEMPLATE_TWO_DAYS_BEFORE=docnudge_two_days_before
INTERAKT_TEMPLATE_PRESCRIPTION=docnudge_prescription
INTERAKT_TEMPLATE_DAY_BEFORE=docnudge_day_before
INTERAKT_TEMPLATE_MORNING=docnudge_morning_of_visit
INTERAKT_TEMPLATE_MISSED_FOLLOWUP=docnudge_missed_followup
INTERAKT_TEMPLATE_WEEKLY_REPORT=docnudge_weekly_report

# Patient portal base URL (prescription share links)
PATIENT_PORTAL_URL=https://patient.docnudge.in
